# ============================================
# 数据库配置
# ============================================

# PostgreSQL 数据库连接字符串
DATABASE_URL=postgresql+asyncpg://autonews:autonewsletter@localhost:5432/autonews
PG_POOL_SIZE=10

# Redis Configuration
REDIS_URL=redis://localhost:6379

# ============================================
# AI Service (choose one)
# ============================================

DEEPSEEK_API_KEY=your_deepseek_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# 内容源配置
# ============================================

# RSS 订阅源列表（逗号分隔，当数据库中没有 sources 时作为后备）
RSS_FEEDS=https://example.com/feed.xml,https://another.com/rss

# ============================================
# 推送渠道配置（至少配置一个）
# ============================================

# 企业微信群机器人 Webhook URL（多个，逗号分隔）
# WECHAT_WEBHOOK_URLS=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# PushPlus Token 列表（微信个人推送，逗号分隔）
# 获取地址: https://www.pushplus.plus
PUSHPLUS_TOKENS=your_pushplus_token_here

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Lark (Feishu) webhook URL
# LARK_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/...

# Whisper transcription service (self-hosted via Docker)
# WHISPER_MODEL=medium   # 可选: tiny, base, small, medium, large-v3
# WHISPER_TIMEOUT=300

# ============================================
# Scheduling
# ============================================

# Cron 表达式（默认: 每周三上午9点）
WEEKLY_CRON=0 9 * * 3

# 立即运行一次（设为 1 跳过定时等待）
IMMEDIATE_RUN=0

# 强制重新处理（设为 1 跳过 URL 去重）
FORCE_RECENT=0

# 日志级别（trace, debug, info, warn, error, fatal）
LOG_LEVEL=info
